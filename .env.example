# Sweden OSINT Tool — Configuration
# Copy this file to .env and fill in your keys.
# The tool works without any keys, but rate limits will be lower.

# GitHub Personal Access Token
# Get one at: https://github.com/settings/tokens (no scopes needed for public data)
# Without token: 60 requests/hour  |  With token: 5000 requests/hour
GITHUB_TOKEN=

# HaveIBeenPwned API Key
# Required for full breach data. Get one at: https://haveibeenpwned.com/API/Key
# Without key: breach names only  |  With key: full breach details
HIBP_API_KEY=

# Shodan API Key (future use)
# Get one at: https://account.shodan.io
SHODAN_API_KEY=

# PIVOT Remote Control API Key(s)
# Generate one: python -c "from api_auth import generate_key, save_key; k=generate_key(); save_key(k); print(k)"
# Comma-separate multiple keys: PIVOT_API_KEY=key1,key2
# Keys can also be stored in .env.api (one PIVOT_API_KEY=... per line)
PIVOT_API_KEY=
